# Rename this file to keystore.properties (gitignored) and fill in real values.
# Points to the upload keystore you created with `keytool -genkey`.
# Losing the keystore file = you can never update this app on Play Store.
# Back it up (encrypted USB / 1Password / encrypted cloud).

storeFile=/Users/besma/keys/wdiy-upload.keystore
storePassword=REPLACE_WITH_YOUR_KEYSTORE_PASSWORD
keyAlias=wdiy
keyPassword=REPLACE_WITH_YOUR_KEY_PASSWORD
